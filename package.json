{
  "name": "@omar391/loopship",
  "version": "1.0.1",
  "description": "Spec workflows, looped until shipped.",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "loopship": "bin/loopship",
    "loopship-fastflow-daemon": "bin/loopship-fastflow-daemon"
  },
  "exports": {
    ".": "./index.ts",
    "./fastflow": "./scripts/loopship_fastflow.ts",
    "./fastflow/daemon": "./scripts/loopship_fastflow_daemon.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    ".loopship/system.yaml",
    ".loopship/signature.yaml",
    ".loopship/docs",
    "README.md",
    "bin",
    "bun.lock",
    "index.ts",
    "call-catalog",
    "!call-catalog/**/*.dev.yaml",
    "references",
    "schemas",
    "scripts",
    "tsconfig.json"
  ],
  "keywords": [
    "loopship",
    "cli",
    "workflow",
    "agent",
    "bun"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=26.0.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "precmdproto:gen": "bun scripts/ensure_cmdproto_deps.mjs",
    "cmdproto:gen": "cmdproto build --generate-only",
    "precmdproto:schema": "bun scripts/ensure_cmdproto_deps.mjs",
    "cmdproto:schema": "bun run scripts/run_cmdproto_schema.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./scripts/verify_flow_schema.test.ts ./scripts/verify_runtime_live.test.ts ./scripts/verify_fastflow_native.test.ts",
    "test:integration": "bun test ./scripts/verify_lifecycle_matrix.integration.ts",
    "verify": "bun run typecheck && bun run test && bun run scripts/verify_system_model.ts && bun run scripts/verify_coherency.ts && bun run scripts/run_cmdproto_schema.ts && bun run scripts/verify_cmdproto_abi.ts && bun run scripts/verify_quest_contract.ts && bun run scripts/verify_runtime_hooks.ts && bun run scripts/verify_runtime_simulation.ts && bun run scripts/verify_runtime_stepper.ts && bun run scripts/report_lifecycle_matrix.ts",
    "verify:lifecycle": "LOOPSHIP_EXECUTE_LIFECYCLE_MATRIX=1 LOOPSHIP_LIFECYCLE_CASES=bugfix,feature-parallel,vague-greenfield bun run scripts/report_lifecycle_matrix.ts",
    "verify:stress": "bun run scripts/verify_lifecycle_stress_matrix.ts",
    "verify:release": "bun run verify && bun run verify:lifecycle && bun run verify:stress",
    "verify:live": "bun run scripts/verify_runtime_live.ts",
    "prepublishOnly": "bun run verify:release"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@cueintent/fastflow": "1.0.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cmdproto": "git+https://github.com/omar391/cmdproto.git#b0d9997544ef265f861ea045035b948a48bc334a",
    "yaml": "^2.8.3"
  },
  "trustedDependencies": [
    "cmdproto"
  ],
  "resolutions": {
    "@cueintent/fastflow": "git+ssh://git@github.com/cueintent/fastflow.git#c0aee6b1529ccb68921f843c7dfe6089fd48dcf1"
  },
  "bundledDependencies": [
    "@cueintent/fastflow"
  ]
}
